import numpy as np
import matplotlib.pyplot as plt

x = np.arange(0, 50) # создание массива числе от 0 до 49 по x

noise = np.random.randn(50) * 0.5 # создаём 50 случайных чисел, уменшили шум, что бы видеть различие между 2x и 3x

y1 = 2 * x + noise #идеальная линия + шум
y2 = 3 * x + noise

plt.scatter(x, y1) # строит график, рисует точки y1
plt.plot(x, 2 * x, label="y = 2x") # рисует идеальную линию. label подпись линии

plt.scatter(x, y2)
plt.plot(x, 3 * x, label="y = 3x")

plt.legend() # показывает подписи линий
plt.show() # показывает график