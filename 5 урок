import numpy as np
import matplotlib.pyplot as plt

x = np.arange(0, 10)
noise = np.random.randn(10)
y = 2 * x + noise

w = 2
y_pred = w * x # предсказание

# считаем ошибку
error = np.mean((y - y_pred) ** 2) # np.mean - берём среднее значение. Возводим в квадрат, что бы убрать минусы и и большие ошибки наказываются сильнее. Это называется MSE - среднее квадратов ошибок. Это число, которое показывает насколько в среднем модель ошибается

plt.scatter(x, y)
plt.plot(x, y_pred)

# линии ошибок
for i in range(len(x)):
    plt.plot([x[i], x[i]], [y[i], y_pred[i]])

# выводим ошибку прямо на графике
plt.title(f"Ошибка модели: {error:.2f}")

plt.show()

# так же я меня w на 0.5, 1, 2 и 3, что бы увидеть разницу ошибки и найти идеальное.